---
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { getPostNum } from "../../utils/content-utils";
import { getTagUrl } from "../../utils/url-utils";
import WidgetLayout from "./WidgetLayout.astro";

const COLLAPSED_HEIGHT = "7.5rem";



interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
const s = getPostNum();
---
<WidgetLayout name="本站统计" id="busuanzi" isCollapsed={false} collapsedHeight={COLLAPSED_HEIGHT} class={className} style={style}>
    <div class="flex gap-2 flex-wrap">
            <script defer src="https://busuanzi.9420.ltd/js"></script>
            <div class="flex gap-2 flex-wrap"><p> 本站文章数 {s} &nbsp;</p> </div>
            <p>本站总访问量 <span id="busuanzi_site_pv"></span> 次</p>
            <p>本站总访客数 <span id="busuanzi_site_uv"></span> 人</p>

    </div>
</WidgetLayout>